<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="com.sixpages.six_pages_voice">

  <!-- Keeps the CPU alive while the SCREEN sleeps. Partial wakelock only. -->
  <uses-permission android:name="android.permission.WAKE_LOCK" />

  <!-- Foreground service, and its microphone type. On Android 14+ the typed
       permission is REQUIRED or the mic is silently muted once backgrounded. -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

  <!-- TELECOM DIAGNOSTIC (car hangup instrument). Lets the app register a
       self-managed VoIP call so the car's End Call button has a Connection to
       land on. MANAGE_OWN_CALLS is required for Telecom to bind to our
       ConnectionService. This is instrument-only; no audio behavior. -->
  <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />

  <application>
    <service
      android:name=".VoiceSessionService"
      android:foregroundServiceType="microphone"
      android:exported="false" />

    <!-- Self-managed ConnectionService. BIND_TELECOM_CONNECTION_SERVICE +
         the intent-filter are how Telecom discovers and binds to us. -->
    <service
      android:name=".CallConnectionService"
      android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE"
      android:exported="true">
      <intent-filter>
        <action android:name="android.telecom.ConnectionService" />
      </intent-filter>
    </service>
  </application>

</manifest>
